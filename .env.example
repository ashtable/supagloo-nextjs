# supagloo-nextjs — local dev + e2e env template.
#
#   cp .env.example .env.local   # then fill in the real values (gitignored)
#
# Next.js loads .env.local for `next dev` automatically; the Vitest e2e harness
# loads it explicitly (tests/e2e/load-env.ts, tests/e2e/global-setup.ts).

# ============================================================================
# Gloo AI — TWO DISTINCT credential sets (design-delta §10.8, task 34-E2).
# These two collide by concept but MUST use different env var names here.
# ============================================================================

# --- (1) Stagehand's OWN LLM (the e2e test-harness AI that drives the browser) ---
# Read by lib/gloo/llm-client.ts to mint a Gloo OAuth token + pick the model for
# Stagehand's extract/observe. This is the HARNESS's brain — unrelated to the app's
# per-user Gloo connections. Required by the nextjs e2e harness (fail-fast, not skip).
GLOO_STAGEHAND_MODEL=gloo-openai-gpt-5-mini
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# --- (2) The APP-UNDER-TEST's Gloo connect credentials ---
# Real Gloo credentials a future real-provider e2e spec (task 35 / 34-E8) types into
# the app's "Connect Gloo" form (PUT /api/connect/gloo → API live verify-then-store).
# Deliberately DISTINCT names so they never clobber Stagehand's own LLM creds above.
# In supagloo-nodejs-api / -dbos this same concept is just GLOO_CLIENT_ID/SECRET (no
# Stagehand there to collide with) — the GLOO_CONNECT_ prefix is nextjs-only.
GLOO_CONNECT_CLIENT_ID=
GLOO_CONNECT_CLIENT_SECRET=

# ============================================================================
# App server env
# ============================================================================

# YouVersion Platform API key. nextjs uses the shorter name YV_APP_KEY (a
# pre-existing divergence from the backends' YOUVERSION_APP_KEY). Required at module
# scope by app/layout.tsx — the app 500s without it.
YV_APP_KEY=

# YouVersion sign-in redirect target (public — reaches the browser bundle).
NEXT_PUBLIC_YV_AUTH_REDIRECT_URL=http://localhost:3000

# Flag-gated mock-session reachability seam (plan D-AUTH). Dev + E2E only; MUST be
# absent/unset in prod so `?mock=` is a no-op there.
NEXT_PUBLIC_SUPAGLOO_DEMO=1

# The supagloo-nodejs-api base URL the BFF route handlers proxy to (server-side only;
# defaults to http://localhost:4000 when unset).
SUPAGLOO_API_URL=http://localhost:4000

# The extended Stagehand seed seam's server gate. `POST /api/test/seed` is a HARD 404
# unless this equals '1' AND NODE_ENV!=='production'. Dev + E2E only; unset in prod.
SUPAGLOO_ENABLE_TEST_SEED=1

# ============================================================================
# Optional e2e knobs (safe to omit)
# ============================================================================

# OpenRouter host for the browser PKCE leg (openrouter-connect.ts). Optional —
# defaults to https://openrouter.ai. The e2e specs shim OpenRouter's interactive
# browser login (design-delta §10.4a), so no real OpenRouter key lives in nextjs; the
# server-side real-key story is the backend repos' OPENROUTER_E2E_TEST_API_KEY.
# NEXT_PUBLIC_OPENROUTER_BASE_URL=https://openrouter.ai

# Optional slug the studio-hydration e2e targets an existing seeded project with.
# SUPAGLOO_E2E_STUDIO_SLUG=
